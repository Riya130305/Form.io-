# MongoDB connection string (local)
MONGO_URI=mongodb://localhost:27017/formio-poc

# Port for the Form.io backend server
PORT=3001

# JWT secret for auth tokens (change in production!)
JWT_SECRET=supersecretkey123

# Admin user created on first boot
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=Admin@1234

# Node environment
NODE_ENV=development
